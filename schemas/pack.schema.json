{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://opendelve.github.io/schemas/v1/pack.schema.json",
  "title": "OpenDelve Pack Manifest",
  "description": "Manifest for an OpenDelve compliance pack. Lives at <pack>/pack.yaml. Defines the pack's identity, framework mappings, controls, dependencies, and capabilities.",
  "type": "object",
  "required": ["schemaVersion", "id", "version", "framework", "name", "description", "files"],
  "properties": {
    "schemaVersion": {
      "type": "string",
      "const": "v1"
    },
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9-]*[a-z0-9]$",
      "description": "Pack identifier. Lowercase, hyphens. Must match the pack directory name."
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$",
      "description": "Semantic version of the pack content."
    },
    "framework": {
      "type": "object",
      "required": ["name", "version"],
      "properties": {
        "name": {
          "type": "string",
          "examples": ["ISO 9001", "SOC 2 Type 2", "ISO 13485", "PCI DSS"]
        },
        "version": {
          "type": "string",
          "description": "Framework edition or year. Example: '2015' for ISO 9001:2015."
        },
        "url": {
          "type": "string",
          "format": "uri",
          "description": "Optional link to the framework's authoritative source."
        }
      }
    },
    "name": {
      "type": "string",
      "minLength": 1,
      "maxLength": 200,
      "description": "Human-readable pack name."
    },
    "description": {
      "type": "string",
      "minLength": 1,
      "maxLength": 1000,
      "description": "One-paragraph description of what this pack provides."
    },
    "depth": {
      "type": "string",
      "enum": ["deep", "starter", "coming-soon"],
      "default": "deep",
      "description": "Honest depth signal. 'starter' = minimal scaffold; 'coming-soon' = stub only."
    },
    "files": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["path", "role"],
        "properties": {
          "path": {
            "type": "string",
            "description": "Path relative to the pack directory."
          },
          "role": {
            "type": "string",
            "enum": ["sop", "workflow", "evidence-schema", "control-map", "policy", "template", "doc"],
            "description": "What this file represents in the compliance model."
          },
          "controlIds": {
            "type": "array",
            "items": { "type": "string" },
            "description": "Optional: which framework controls this file maps to."
          }
        },
        "additionalProperties": false
      }
    },
    "controls": {
      "type": "array",
      "description": "Framework controls this pack covers, by id.",
      "items": {
        "type": "object",
        "required": ["id", "title"],
        "properties": {
          "id": {
            "type": "string",
            "description": "Framework-native control id. Example: '8.5.1' for ISO 9001 Operation Control."
          },
          "title": {
            "type": "string"
          },
          "scope": {
            "type": "string",
            "enum": ["covered", "partial", "out-of-scope"],
            "default": "covered"
          }
        },
        "additionalProperties": false
      }
    },
    "mappings": {
      "type": "array",
      "description": "Cross-framework control mappings (e.g., ISO 13485 control X aligns with ISO 9001 control Y).",
      "items": {
        "type": "object",
        "required": ["fromControl", "toFramework", "toControl"],
        "properties": {
          "fromControl": { "type": "string" },
          "toFramework": { "type": "string" },
          "toControl": { "type": "string" },
          "alignment": {
            "type": "string",
            "enum": ["equivalent", "subset", "superset", "related"],
            "default": "related"
          }
        },
        "additionalProperties": false
      }
    },
    "dependencies": {
      "type": "array",
      "description": "Other packs this pack depends on (e.g., ISO 13485 depends on ISO 9001).",
      "items": {
        "type": "object",
        "required": ["pack", "version"],
        "properties": {
          "pack": { "type": "string" },
          "version": {
            "type": "string",
            "description": "Semver constraint (e.g., '^0.1.0' or '>=0.2.0')."
          }
        },
        "additionalProperties": false
      }
    },
    "capabilities": {
      "type": "array",
      "description": "What this pack enables. Used by `verify` to check coverage.",
      "items": {
        "type": "string",
        "enum": [
          "sop-management",
          "evidence-collection",
          "approval-signing",
          "audit-packet",
          "training-records",
          "vendor-approval",
          "complaint-handling",
          "deviation-capa",
          "release-control",
          "change-control"
        ]
      },
      "uniqueItems": true
    }
  },
  "additionalProperties": false
}
